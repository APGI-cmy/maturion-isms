# MMM — Environment Variables Example
#
# Authority: TR-053 (FR-072), architecture.md §A8.4
# Version:   1.0.0
# Stage:     Architecture (Stage 5)
# Date:      2026-04-14
#
# Copy this file to .env.local and fill in actual values.
# DO NOT commit .env.local to source control.
# Add .env.local to .gitignore before populating secrets.
#
# ─────────────────────────────────────────────────────────
# SECRETS MANAGEMENT RULE (TR-053):
#   SUPABASE_SERVICE_ROLE_KEY, AIMC_SERVICE_TOKEN, and
#   PIT_SERVICE_TOKEN are secrets. They must NEVER be:
#   - Logged or printed
#   - Exposed to the frontend (VITE_ prefix is PROHIBITED for these)
#   - Committed to source control
#   Set these in your CI/CD environment or Vercel dashboard only.
# ─────────────────────────────────────────────────────────

# ── Supabase Configuration ────────────────────────────────

# Supabase project URL (used by both frontend and Edge Functions)
# Scope: Frontend + Edge Functions
# Source: Supabase project dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to expose to frontend)
# Scope: Frontend only
# Source: Supabase project dashboard → Settings → API → anon (public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SECRET
# Scope: Edge Functions only — NEVER expose to frontend
# VITE_ prefix is PROHIBITED for this variable (TR-053)
# Source: Supabase project dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AIMC Gateway ─────────────────────────────────────────

# AIMC gateway base URL (no trailing slash)
# Scope: Edge Functions only
# Source: CS2-configured AIMC deployment URL (Render or Vercel)
# Example: https://aimc-prod.render.com
AIMC_BASE_URL=https://your-aimc-instance.example.com

# AIMC service-to-service authentication token — SECRET
# Scope: Edge Functions only — NEVER expose to frontend
# Source: CS2-issued service token for MMM → AIMC calls
AIMC_SERVICE_TOKEN=your-aimc-service-token-here

# ── PIT Integration ───────────────────────────────────────

# PIT import endpoint base URL (no trailing slash)
# Scope: Edge Functions only
# Source: CS2-configured PIT deployment URL
# Example: https://pit-prod.render.com
PIT_BASE_URL=https://your-pit-instance.example.com

# PIT service-to-service authentication token — SECRET
# Scope: Edge Functions only — NEVER expose to frontend
# Source: CS2-issued service token for MMM → PIT calls
PIT_SERVICE_TOKEN=your-pit-service-token-here

# ── Application Environment ───────────────────────────────

# Environment identifier used by Edge Functions for conditional behaviour
# Scope: Edge Functions
# Values: development | staging | production
# Default: development
MMM_ENV=development

# ─────────────────────────────────────────────────────────
# VERCEL-MANAGED VARIABLES (do not set manually):
#
#   VERCEL_URL — auto-injected by Vercel on each deployment
#   Do not set this in .env.local; it is not a deployment concern.
#
# Set the variables above (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY,
# SUPABASE_SERVICE_ROLE_KEY, AIMC_BASE_URL, AIMC_SERVICE_TOKEN,
# PIT_BASE_URL, PIT_SERVICE_TOKEN, MMM_ENV) in the Vercel dashboard
# under: Project → Settings → Environment Variables
# Apply to: Production, Preview, Development as appropriate.
# ─────────────────────────────────────────────────────────

# ── Optional: Local Development Overrides ────────────────

# Uncomment to override Supabase DB URL for local Supabase CLI use.
# Only relevant when running `supabase start` locally.
# SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
