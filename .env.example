# MAT Liveness Test Suite — Environment Variables
# Copy this file to .env.local and fill in your values.
# See modules/mat/tests/liveness/README-LIVENESS.md for details.

# ─── Liveness test credentials ────────────────────────────────────────────────
LIVENESS_TEST_EMAIL=
LIVENESS_TEST_PASSWORD=
BASE_URL=https://your-mat-deployment.vercel.app

# ─── AI endpoint URLs ─────────────────────────────────────────────────────────
# AI_GATEWAY_URL — Base URL of the deployed mat-ai-gateway FastAPI service.
# Deployment instructions, environment variables, health check verification,
# and rollback procedure: docs/runbooks/mat-ai-gateway-deployment.md
AI_GATEWAY_URL=
AI_DOC_PARSER_URL=
AI_SCORING_URL=
AI_CHAT_URL=
AI_REPORT_URL=

# ─── AI latency thresholds (ms) ───────────────────────────────────────────────
AI_WARN_THRESHOLD_MS=15000
AI_FAIL_THRESHOLD_MS=30000
AI_REPORT_TIMEOUT_MS=120000
