{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app",
      "statusCode": 308
    },
    {
      "source": "/modules",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app/modules",
      "statusCode": 308
    },
    {
      "source": "/marketing/project-implementation",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app/marketing/project-implementation",
      "statusCode": 308
    },
    {
      "source": "/subscribe",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app/subscribe",
      "statusCode": 308
    },
    {
      "source": "/subscribe/checkout",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app/subscribe/checkout",
      "statusCode": 308
    },
    {
      "source": "/auth",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app/auth",
      "statusCode": 308
    },
    {
      "source": "/login",
      "has": [
        {
          "type": "host",
          "value": "maturion-pit.vercel.app"
        }
      ],
      "destination": "https://maturion-isms-portal.vercel.app/login",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
